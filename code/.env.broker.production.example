APP_NAME="Share Capsules Key Broker"
APP_ENV=production
APP_KEY=replace-with-broker-specific-application-key
APP_DEBUG=false
APP_URL=https://broker.sharecapsules.com

LOG_CHANNEL=json_stderr
LOG_LEVEL=info
BROKER_AUDIT_LOG_LEVEL=notice

SHARECAPSULES_COMPONENT=broker
SHARECAPSULES_ENVIRONMENT=production
SHARECAPSULES_DEPLOYMENT_ID=production-broker
SHARECAPSULES_BROKER_URL=https://broker.sharecapsules.com
SHARECAPSULES_BROKER_CONTROL_PLANE_TOKEN=replace-with-dedicated-broker-control-plane-token
SHARECAPSULES_BROKER_CALLBACK_TOKEN=replace-with-dedicated-broker-callback-token
SHARECAPSULES_CONTROL_PLANE_INTERNAL_URL=https://app.sharecapsules.com
SHARECAPSULES_CTX_ISSUER=https://sharecapsules.com
SHARECAPSULES_CTX_INTERNAL_URL=https://app.sharecapsules.com
SHARECAPSULES_BROKER_AUDIT_CHANNEL=broker_audit

BROKER_KMS_DRIVER=managed
BROKER_KMS_KEY_ID=replace-with-managed-kms-or-hsm-key-identifier

DB_CONNECTION=broker
BROKER_DB_HOST=replace-with-production-broker-mysql-host
BROKER_DB_PORT=3306
BROKER_DB_DATABASE=sharecapsules_broker
BROKER_DB_USERNAME=replace-with-dedicated-broker-database-user
BROKER_DB_PASSWORD=replace-with-dedicated-broker-database-password
