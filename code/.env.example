APP_NAME="Share Capsules"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:3003

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=json_stderr
LOG_STACK=json_stderr
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

SHARECAPSULES_ENVIRONMENT=development
SHARECAPSULES_DEPLOYMENT_ID=local
SHARECAPSULES_EXTENSION_CHANNEL=development
SHARECAPSULES_EXTENSION_ID=development-not-configured
SHARECAPSULES_OAUTH_EXTENSION_CLIENT_ID=development-not-configured
SHARECAPSULES_CTX_ISSUER=http://localhost:3003
SHARECAPSULES_BROKER_URL=http://localhost:3003

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sharecapsules_dev
DB_USERNAME=sharecapsules_app
DB_PASSWORD=dev_app_password_change_me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="do-not-reply@sharecapsules.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
