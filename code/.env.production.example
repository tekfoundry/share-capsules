APP_NAME="Share Capsules"
APP_ENV=production
APP_KEY=replace-with-production-app-key
APP_DEBUG=false
APP_URL=https://sharecapsules.com

LOG_CHANNEL=json_stderr
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=replace-with-production-mysql-host
DB_PORT=3306
DB_DATABASE=sharecapsules
DB_USERNAME=replace-with-production-database-user
DB_PASSWORD=replace-with-production-database-password

SESSION_DRIVER=database
QUEUE_CONNECTION=redis
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=replace-with-production-redis-host
REDIS_PASSWORD=replace-with-production-redis-password
REDIS_PORT=6379

MAIL_MAILER=mailgun
MAILGUN_DOMAIN=replace-with-production-mailgun-domain
MAILGUN_SECRET=replace-with-production-mailgun-api-key
MAILGUN_ENDPOINT=api.mailgun.net
MAIL_FROM_ADDRESS="do-not-reply@sharecapsules.com"
MAIL_FROM_NAME="${APP_NAME}"

SHARECAPSULES_ENVIRONMENT=production
SHARECAPSULES_COMPONENT=control-plane
SHARECAPSULES_DEPLOYMENT_ID=production-primary
SHARECAPSULES_EXTENSION_CHANNEL=production
SHARECAPSULES_EXTENSION_ID=replace-with-production-extension-id
SHARECAPSULES_OAUTH_EXTENSION_CLIENT_ID=replace-with-production-oauth-client-id
SHARECAPSULES_OAUTH_EXTENSION_REDIRECT_URI=https://replace-with-production-extension-id.chromiumapp.org/oauth/callback
SHARECAPSULES_CTX_ISSUER=https://sharecapsules.com
SHARECAPSULES_BROKER_URL=https://broker.sharecapsules.com
SHARECAPSULES_BROKER_CONTROL_PLANE_TOKEN=replace-with-dedicated-broker-control-plane-token
SHARECAPSULES_BROKER_CALLBACK_TOKEN=replace-with-dedicated-broker-callback-token
