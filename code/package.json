{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "engines": {
        "node": ">=24.9.0 <25",
        "npm": ">=11.6.0 <12"
    },
    "scripts": {
        "build": "npm run generate:schema-validators && npm run typecheck && vite build && node scripts/build-extension.mjs",
        "build:extension": "npm run generate:schema-validators && npm run typecheck && node scripts/build-extension.mjs",
        "benchmark:image-envelope": "node scripts/static-image-envelope-benchmark.mjs",
        "dev": "vite",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "generate:schema-validators": "node scripts/generate-schema-validators.mjs",
        "lint": "eslint apps packages resources/js scripts tests/Browser playwright.config.ts vite.config.js",
        "release:supply-chain-check": "node scripts/release-supply-chain-check.mjs",
        "test:browser": "playwright test",
        "test:ts": "vitest run --passWithNoTests",
        "typecheck": "tsc --build --pretty false"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.11.3",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.0",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^24.13.2",
        "ajv": "^8.20.0",
        "ajv-formats": "^3.0.1",
        "concurrently": "^10.0.3",
        "eslint": "^10.5.0",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.0",
        "vitest": "^4.1.9"
    },
    "dependencies": {
        "@laravel/passkeys": "^0.2.0"
    }
}
