{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "engines": {
        "node": ">=24.9.0 <25",
        "npm": ">=11.6.0 <12"
    },
    "scripts": {
        "build": "npm run typecheck && vite build",
        "dev": "vite",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint apps packages resources/js vite.config.js",
        "test:ts": "vitest run --passWithNoTests",
        "typecheck": "tsc --build --pretty false"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tailwindcss/vite": "^4.0.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.5.0",
        "laravel-vite-plugin": "^3.1",
        "prettier": "^3.8.4",
        "tailwindcss": "^4.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.1",
        "vite": "^8.0.0",
        "vitest": "^4.1.9"
    }
}
