{
    "manifest_version": 3,
    "name": "Share Capsules (Development)",
    "version": "0.1.0",
    "description": "Creates and views Share Capsules without exposing protected content to websites.",
    "key": "",
    "permissions": ["identity", "storage"],
    "host_permissions": ["http://localhost:3003/*", "http://localhost:3004/*"],
    "optional_host_permissions": ["https://*/*"],
    "background": {
        "service_worker": "service-worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["http://localhost:3003/studio/capsules/create"],
            "js": ["creator-handoff.js"],
            "run_at": "document_start"
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
}
